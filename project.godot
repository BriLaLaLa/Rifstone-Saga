; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="IdleAFKStarter"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.5")

[autoload]

GameLogger="*res://scripts/GameLogger.gd"
GameState="*res://scripts/GameState.gd"
BonusDatabase="*res://scripts/crafting/BonusDatabase.gd"
GemCrafting="*res://scripts/crafting/GemCrafting.gd"
ItemDropGenerator="*res://scripts/battle/ItemDropGenerator.gd"
IData="*res://scripts/data/ItemDatabase.gd"
TooltipManager="*res://scripts/ui/TooltipManager.gd"
EnemyDatabase="*res://scripts/battle/EnemyDatabase.gd"
GatheringDatabase="*res://scripts/gathering/GatheringDatabase.gd"
EnhancementSystem="*res://scripts/systems/EnhancementSystem.gd"
QuestSystem="*res://scripts/systems/QuestSystem.gd"
LootOrbManager="*res://scripts/battle/LootOrbManager.gd"
XpOrbManager="*res://scripts/battle/XpOrbManager.gd"
GoldOrbManager="*res://scripts/battle/GoldOrbManager.gd"
LootNotificationManager="*res://scripts/ui/LootNotificationManager.gd"

[gui]

timers/tooltip_delay_sec=0.2
